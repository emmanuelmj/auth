# Normalize line endings to LF on commit for all text files.
# This prevents gofmt differences between Windows (CRLF) and Linux/macOS (LF) CI runners.
* text=auto eol=lf

# Go source — always LF
*.go text eol=lf

# Config / CI
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.sum  text eol=lf
*.mod  text eol=lf
